<mvc:View
    controllerName="ns.backorder.controller.Main"
    xmlns:mvc="sap.ui.core.mvc"
    displayBlock="true"
    xmlns="sap.m"
    xmlns:f="sap.f"
    xmlns:layout="sap.ui.layout"
    xmlns:fb="sap.ui.comp.filterbar"
    xmlns:core="sap.ui.core">
    <f:DynamicPage id="dynamicPageId" headerExpanded="true">
        <f:title>
            <f:DynamicPageTitle>
                <f:heading>
                    <Title text="BackOrder History Items"/>
                </f:heading>
            </f:DynamicPageTitle>
        </f:title>
        <f:header>
            <f:DynamicPageHeader pinnable="true">
                <fb:FilterBar id="filterbar" persistencyKey="myPersKey" useToolbar="false" search=".onSearch" filterContainerWidth="12rem">
                    <fb:filterGroupItems>
                        <fb:FilterGroupItem name="soldTo" label="Sold-To" groupName="Group1" visibleInFilterBar="true">
                            <fb:control>
                                <Input id="idSoldTo" placeholder="Enter Sold-To" required="true" value="203800"/>
                            </fb:control>
                        </fb:FilterGroupItem>
                        <fb:FilterGroupItem name="shipTo" label="Ship-To" groupName="Group1" visibleInFilterBar="true">
                            <fb:control>
                                <MultiInput id="idShipTo" placeholder="Enter Ship-To(s)" tokenUpdate=".onTokenUpdate"/>
                            </fb:control>
                        </fb:FilterGroupItem>
                        <fb:FilterGroupItem name="searchBy" label="Search By" groupName="Group1" visibleInFilterBar="true">
                            <fb:control>
                                <Select id="idSearchBy">
                                    <core:Item key="orderNumber" text="Order Number"/>
                                    <core:Item key="invoiceNumber" text="Invoice Number"/>
                                    <core:Item key="poNumber" text="PO Number"/>
                                    <core:Item key="itemNumber" text="Item Number"/>
                                </Select>
                            </fb:control>
                        </fb:FilterGroupItem>
                        <fb:FilterGroupItem name="search" label="Search Value" groupName="Group1" visibleInFilterBar="true">
                            <fb:control>
                                <SearchField id="idSearchValue" placeholder="Search..."/>
                            </fb:control>
                        </fb:FilterGroupItem>
                        <fb:FilterGroupItem name="dateRange" label="Date Range" groupName="Group1" visibleInFilterBar="true">
                            <fb:control>
                                <DateRangeSelection id="idDateRange" displayFormat="yyyy-MM-dd"/>
                            </fb:control>
                        </fb:FilterGroupItem>
                    </fb:filterGroupItems>
                </fb:FilterBar>
            </f:DynamicPageHeader>
        </f:header>
        <f:content>
            <Table id="idBackOrderTable"
                inset="false"
                items="{
                    path: '/BackOrderItems',
                    parameters: {
                        $count: true,
                        $top: 12
                    }
                }"
                sticky="ColumnHeaders,HeaderToolbar">
                <headerToolbar>
                    <OverflowToolbar>
                        <content>
                            <Title id="tableTitle" text="Items ({$count})"/>
                            <ToolbarSpacer />
                            <Button icon="sap-icon://sort" press=".onSort"/>
                        </content>
                    </OverflowToolbar>
                </headerToolbar>
                <columns>
                    <Column minScreenWidth="Tablet" demandPopin="true">
                        <Text text="Product Code" />
                    </Column>
                    <Column>
                        <Text text="Order Number" />
                    </Column>
                    <Column minScreenWidth="Tablet" demandPopin="true">
                        <Text text="Date" />
                    </Column>
                    <Column hAlign="End">
                        <Text text="Quantity" />
                    </Column>
                    <Column hAlign="End">
                        <Text text="Price" />
                    </Column>
                    <Column hAlign="End">
                        <Text text="Total" />
                    </Column>
                    <Column minScreenWidth="Tablet" demandPopin="true" hAlign="Center">
                        <Text text="Status" />
                    </Column>
                </columns>
                <items>
                    <ColumnListItem vAlign="Middle">
                        <cells>
                            <ObjectIdentifier title="{productCode}" text="{itemNumber}"/>
                            <Text text="{erpOrderNumber}" />
                            <Text text="{
                                path: 'orderDate',
                                type: 'sap.ui.model.type.DateTime',
                                formatOptions: {
                                    style: 'medium'
                                }
                            }" />
                            <Text text="{quantity}" />
                            <ObjectNumber number="{dealerPrice}" unit="{currency}" />
                            <ObjectNumber number="{totalPrice}" unit="{currency}" state="Information"/>
                            <ObjectStatus 
                                text="{= ${orderStatus} === '3' ? 'Completed' : 'Pending'}" 
                                state="{= ${orderStatus} === '3' ? 'Success' : 'Warning'}"/>
                        </cells>
                    </ColumnListItem>
                </items>
            </Table>
        </f:content>
        <f:footer>
            <OverflowToolbar>
                <ToolbarSpacer />
                <Button id="idPrevButton" icon="sap-icon://navigation-left-arrow" press=".onPageChange" enabled="false"/>
                <Text id="idPageNumber" text="Page 1"/>
                <Button id="idNextButton" icon="sap-icon://navigation-right-arrow" press=".onPageChange"/>
            </OverflowToolbar>
        </f:footer>
    </f:DynamicPage>
</mvc:View>
